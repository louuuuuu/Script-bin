FIELDS=("is_active" "username" "email" "email_address" "created_at" "last_login" "first_name" "last_name" "role" \
        "AdminUser" "adminuser" "Role" "Permission" "permission" "Policy" "policy" "StaffAccount" "staffaccount")

for field in "${FIELDS[@]}"; do
  echo "Testing field: $field"

  # Use subfield for objects to avoid GraphQL errors
  RESPONSE=$(curl -s -X POST https://exchange-api.bumba.global/graphql \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer YOUR_TOKEN" \
    -d "{\"query\":\"query { users { $field { __typename } } }\"}")

  # Fallback for scalars: query without subfield
  if [[ $RESPONSE == *"Cannot query field"* ]]; then
    RESPONSE=$(curl -s -X POST https://exchange-api.bumba.global/graphql \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer YOUR_TOKEN" \
      -d "{\"query\":\"query { users { $field } }\"}")
  fi

  if [[ $RESPONSE != *"Cannot query field"* ]]; then
    echo "✅ Field exists: $field"
  else
    echo "❌ Field does NOT exist: $field"
  fi
done
